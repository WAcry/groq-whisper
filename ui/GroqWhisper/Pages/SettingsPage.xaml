<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GroqWhisper.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Disabled">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Settings"
                       Style="{StaticResource SubtitleTextBlockStyle}" />

            <StackPanel Spacing="8">
                <TextBlock Text="Groq API Key" />
                <PasswordBox x:Name="ApiKeyPasswordBox"
                             PlaceholderText="Paste your Groq API key" />
                <TextBox x:Name="ApiKeyRevealBox"
                         PlaceholderText="Paste your Groq API key"
                         Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="RevealButton"
                            Content="Reveal"
                            Click="Reveal_Click" />
                    <Button x:Name="HideButton"
                            Content="Hide"
                            Click="Hide_Click"
                            Visibility="Collapsed" />
                    <Button x:Name="ClearButton"
                            Content="Clear Key"
                            Click="ClearKey_Click" />
                </StackPanel>
                <TextBlock x:Name="KeyStateText"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ComboBox x:Name="DefaultModelBox"
                      Header="Default Model"
                      SelectedIndex="0"
                      Width="300">
                <ComboBoxItem Content="Speed (whisper-large-v3-turbo)" Tag="whisper-large-v3-turbo" />
                <ComboBoxItem Content="Accuracy (whisper-large-v3)" Tag="whisper-large-v3" />
            </ComboBox>

            <TextBox x:Name="LanguageBox"
                     Header="Language (optional)"
                     PlaceholderText="e.g., en, zh, ja" />

            <NumberBox x:Name="WindowSecondsBox"
                       Header="Window Seconds"
                       Value="30"
                       Minimum="5" Maximum="120"
                       SpinButtonPlacementMode="Compact" />

            <NumberBox x:Name="HopSecondsBox"
                       Header="Hop Seconds"
                       Value="5"
                       Minimum="1" Maximum="30"
                       SpinButtonPlacementMode="Compact" />

            <TextBlock x:Name="MutatingStateText"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords" />

            <Button Content="Save Settings"
                    x:Name="SaveButton"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="Save_Click" />

            <TextBlock x:Name="StatusText"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12" />
        </StackPanel>
    </ScrollViewer>
</Page>
