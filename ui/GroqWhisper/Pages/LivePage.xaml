<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GroqWhisper.Pages.LivePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:GroqWhisper.ViewModels"
    NavigationCacheMode="Required">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Status Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16">
            <Border CornerRadius="4" Padding="8,4"
                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}">
                <TextBlock Text="{x:Bind ViewModel.StateDisplay, Mode=OneWay}"
                           FontSize="12" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Model:" />
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Text="{x:Bind ViewModel.ModelDisplay, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Duration:" />
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Text="{x:Bind ViewModel.DurationDisplay, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Ticks:" />
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Text="{x:Bind ViewModel.TickCountDisplay, Mode=OneWay}" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center" FontSize="12"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}" />
        </StackPanel>

        <!-- Transcription Area -->
        <Border Grid.Row="1"
                CornerRadius="8"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="16">
                <RichTextBlock x:Name="TranscriptionBlock"
                               FontSize="16"
                               LineHeight="28"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True">
                    <Paragraph>
                        <Run x:Name="CommittedRun"
                             Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                             Text="{x:Bind ViewModel.CommittedText, Mode=OneWay}" />
                        <Run x:Name="TailRun"
                             Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                             Text="{x:Bind ViewModel.TailText, Mode=OneWay}" />
                    </Paragraph>
                </RichTextBlock>
            </ScrollViewer>
        </Border>

        <!-- Control Bar -->
        <CommandBar Grid.Row="2" DefaultLabelPosition="Right">
            <AppBarButton Label="Start"
                          Command="{x:Bind ViewModel.StartCommand}"
                          IsEnabled="{x:Bind ViewModel.CanStart, Mode=OneWay}">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Play" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Stop"
                          Command="{x:Bind ViewModel.StopCommand}"
                          IsEnabled="{x:Bind ViewModel.CanStop, Mode=OneWay}">
                <AppBarButton.Icon>
                    <SymbolIcon Symbol="Stop" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarElementContainer>
                <ComboBox x:Name="ModelSelector"
                          Width="160"
                          SelectedIndex="{x:Bind ViewModel.SelectedModelIndex, Mode=TwoWay}"
                          SelectionChanged="ModelSelector_SelectionChanged">
                    <ComboBoxItem Content="Speed" Tag="whisper-large-v3-turbo" />
                    <ComboBoxItem Content="Accuracy" Tag="whisper-large-v3" />
                </ComboBox>
            </AppBarElementContainer>
            <CommandBar.SecondaryCommands>
                <AppBarButton Label="Copy"
                              Command="{x:Bind ViewModel.CopyCommand}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Copy" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Export"
                              Command="{x:Bind ViewModel.ExportCommand}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Save" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Grid>
</Page>
